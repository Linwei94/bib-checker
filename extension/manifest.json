{
  "manifest_version": 3,
  "name": "BibTeX Checker",
  "version": "2.0",
  "description": "BibTeX reference checker with auto-fetch from Google Scholar.",
  "action": {
    "default_title": "BibTeX Checker",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs"],
  "content_scripts": [
    {
      "matches": ["*://scholar.google.com/scholar*"],
      "js": ["scholar-search.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "*://scholar.googleusercontent.com/*"
  ]
}
